#!/bin/sh
set -eu

python3 scripts/workflow.py doctor
python3 scripts/workflow.py hook pre_command --command-text "git push $*"

task_id="${WORKFLOW_TASK_ID:-}"
if [ -n "$task_id" ]; then
  phase_id="${WORKFLOW_PHASE_ID:-}"
  if [ -z "$phase_id" ]; then
    phase_id="$(python3 scripts/workflow.py status "$task_id" --field active_phase_id 2>/dev/null || true)"
  fi
  python3 scripts/workflow.py hook pre_push --task-id "$task_id" --phase-id "$phase_id" --command-text "git push $*"
else
  python3 scripts/workflow.py hook pre_push --command-text "git push $*"
fi
