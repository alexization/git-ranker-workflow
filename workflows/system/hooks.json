{
  "version": 2,
  "events": {
    "pre_command": [
      "dangerous_cmd_guard"
    ],
    "pre_push": [
      "dangerous_cmd_guard"
    ],
    "pre_complete": [
      "user_validation_guard"
    ]
  },
  "guards": {
    "dangerous_cmd_guard": {
      "blocked_patterns": [
        "rm\\s+-rf",
        "git\\s+reset\\s+--hard",
        "git\\s+checkout\\s+--",
        "git\\s+clean\\s+-fd",
        "git\\s+push(?:\\s+\\S+)*\\s+--force(?:\\S+)?",
        "git\\s+push(?:\\s+\\S+)*\\s+-[A-Za-z]*f[A-Za-z]*",
        "DROP\\s+TABLE",
        "TRUNCATE\\s+TABLE"
      ]
    }
  }
}
