# compose / host port rules
BACKEND_HTTP_PORT=8080
BACKEND_MANAGEMENT_PORT=9090
CLIENT_PORT=3000
MYSQL_PORT=3307
PROMETHEUS_PORT=9091
LOKI_PORT=3100

# database
MYSQL_DATABASE=git_ranker
MYSQL_USER=git_ranker
MYSQL_PASSWORD=git_ranker
MYSQL_ROOT_PASSWORD=git_ranker_root

# backend runtime profile
SPRING_PROFILE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=update
BATCH_CHUNK_SIZE=100

# auth placeholders for public ranking runtime
GITHUB_CLIENT_ID=placeholder-client-id
GITHUB_CLIENT_SECRET=placeholder-client-secret
GITHUB_REDIRECT_URI=http://localhost:8080/login/oauth2/code/github
GITHUB_API_TOKENS=placeholder-token
JWT_SECRET=c3RhbmRhcmQtdmVyaWZpY2F0aW9uLXJ1bnRpbWUtc2VjcmV0LXN0YW5kYXJkLXZlcmlmaWNhdGlvbi1ydW50aW1lLXNlY3JldA==
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=1209600000

# runtime-only backend overrides
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_OAUTH2_AUTHORIZED_REDIRECT_URI=http://localhost:3000/auth/callback
APP_COOKIE_DOMAIN=localhost
APP_COOKIE_SECURE=false

# client public origins
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
